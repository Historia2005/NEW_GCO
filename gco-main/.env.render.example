# Copy these keys into Render → Web Service → Environment (GCOFIN-style setup).
# Database: Railway MySQL (public proxy). App: Render Web Service.

NODE_ENV=production
APP_BASE_URL=https://gcofin.onrender.com

JWT_SECRET=replace_with_long_random_string
SESSION_SECRET=replace_with_long_random_string
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_NAME=gco.sid

ALLOW_PASSWORD_LOGIN=true
ENABLE_GOOGLE_OAUTH=true
GOOGLE_CLIENT_ID=823051603357-14j2n2knsqdaoiskivum43gs1j0a4aba.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_OAUTH_HOSTED_DOMAIN=

# Railway MySQL → Variables tab (use public/proxy host, not mysql.railway.internal)
DB_HOST=viaduct.proxy.rlwy.net
DB_PORT=10131
DB_USER=root
DB_PASSWORD=your_railway_mysql_password
DB_NAME=railway
DB_SSL=true
DB_CONNECT_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_app_password
MAIL_FROM=noreply@xu.edu.ph
NOTIFICATION_ALLOWED_DOMAINS=my.xu.edu.ph,xu.edu.ph

ADMIN_EMAILS=admin@xu.edu.ph

GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
